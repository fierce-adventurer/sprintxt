{
  "manifest_version": 3,
  "name": "Sprintxt AI",
  "version": "1.0",
  "description": "Enhance professional writing via a secure local AI proxy.",
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["popup.css"],
      "all_frames": true 
    }
  ],
  "action": {
    "default_popup": "index.html"
  }
}